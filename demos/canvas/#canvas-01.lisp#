;;;; ./demos/canvas/canvas-01.lisp

(in-package :mnas-sdl3-gui/demos/canvas)

(defun demo-canvas-01 ()
  "Create and return a small canvas widget for inspection from the REPL." 
  (make-canvas-demo :w 480 :h 320))

(defun split-string (string)
  "Split STRING on whitespace into a list of substrings." 
  (let ((out '()) (start 0) (len (length string)))
    (flet ((push-sub (s e)
             (when (< s e)
               (push (subseq string s e) out))))
      (loop for i from 0 below len do
        (if (char= (aref string i) #\Space)
            (progn (push-sub start i) (setf start (1+ i)))
            (when (= i (1- len)) (push-sub start len))))
      (nreverse out))))

(defun parse-number (str)
  "Parse STR into a number (integer or float). Returns NIL on failure." 
  (ignore-errors
    (multiple-value-bind (val pos) (read-from-string str)
      (when (and pos (numberp val)) val))))

(defun canvas-screenshot-svg (canvas path &key (width (mnas-sdl3-gui/widgets:widget-width canvas)) (height (mnas-sdl3-gui/widgets:widget-height canvas)))
  "Write current canvas scene into a simple SVG file at PATH.
This is a lightweight screenshot helper that visualizes circle items from the scene." 
  (with-open-file (out path :direction :output :if-exists :supersede :if-does-not-exist :create)
    (format out "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"~A\" height=\"~A\">~%" width height)
    ;; background
    (format out "<rect width=\"100%\" height=\"100%\" fill=\"rgb(240,240,240)\"/>~%")
    (when (and (mnas-sdl3-gui/widgets:canvas-2d-widget-scene canvas)
               (listp (mnas-sdl3-gui/widgets:canvas-2d-widget-scene canvas)))
      (dolist (item (mnas-sdl3-gui/widgets:canvas-2d-widget-scene canvas))
        (when (and (consp item) (eq (car item) :circle))
          (destructuring-bind (_ tag cx cy r color) item
            (multiple-value-bind (sx sy) (mnas-sdl3-gui/widgets:world-to-screen canvas cx cy)
              (let* ((col (if (and (listp color) (= (length color) 4))
                              (format nil "rgb(~A,~A,~A)" (first color) (second color) (third color))
                              "black")))
                (format out "<circle cx=\"~A\" cy=\"~A\" r=\"~A\" fill=\"~A\" stroke=\"black\"/>~%" sx sy r col)))))))
    (format out "</svg>~%")))

(defun demo-canvas-01-run ()
  "Simple REPL-driven interactive loop for the canvas demo.
Supported commands (entered at REPL):
- pan DX DY
- zoom FACTOR [CX CY]
- screenshot PATH
- dump-scene PATH (writes printed scene)
- quit

The loop reads commands from *query-io* until `quit` is entered." 
  (let ((canvas (demo-canvas-01))
        (running t))
    (format t "Canvas demo interactive loop. Commands: pan, zoom, screenshot, dump-scene, quit~%")
    (loop while running do
      (format t "canvas> ") (finish-output)
      (let* ((line (read-line *query-io* nil nil)))
        (when line
             (let* ((parts (remove-if #'(lambda (s) (string= s ""))
                   (mapcar (lambda (s) (string-trim '(#\Space #\Tab) s))
                      (split-string line))))
               (cmd (and parts (string-downcase (first parts)))))
            (cond
              ((string= cmd "pan")
               (let* ((dx (parse-number (second parts))) (dy (parse-number (third parts))))
                 (when (and dx dy)
                   (mnas-sdl3-gui/widgets:canvas-2d-pan-by canvas dx dy)
                   (format t "panned -> offset: ~A,~A~%"
                           (mnas-sdl3-gui/widgets:canvas-2d-widget-viewport-offset-x canvas)
                           (mnas-sdl3-gui/widgets:canvas-2d-widget-viewport-offset-y canvas)))))
              ((string= cmd "zoom")
               (let* ((factor (parse-number (second parts)))
                      (cx (and (third parts) (parse-number (third parts))))
                      (cy (and (fourth parts) (parse-number (fourth parts)))))
                 (when factor
                   (mnas-sdl3-gui/widgets:canvas-2d-zoom-by canvas factor
                                                            (or cx (/ (mnas-sdl3-gui/widgets:widget-width canvas) 2))
                                                            (or cy (/ (mnas-sdl3-gui/widgets:widget-height canvas) 2)))
                   (format t "zoom -> scale: ~A~%" (mnas-sdl3-gui/widgets:canvas-2d-widget-viewport-scale canvas)))))
              ((string= cmd "screenshot")
               (let ((path (second parts)))
                 (canvas-screenshot-svg canvas path)
                 (format t "wrote ~A~%" path)))
              ((string= cmd "dump-scene")
               (let ((path (second parts)))
                 (with-open-file (out path :direction :output :if-exists :supersede)
                   (pprint (mnas-sdl3-gui/widgets:canvas-2d-widget-scene canvas) out))
                 (format t "scene dumped to ~A~%" path)))
              ((string= cmd "quit") (setf running nil))
              (t (format t "unknown command: ~A~%" cmd)))))))))

